{
    // Workspaces
    "niri/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
    			"urgent": "ï†’",
    			"active": "ï„‘",
    			"default": "ï„‘"
        },
        "persistent-workspaces": {
            // START WORKSPACES
            "*": 5
            // END WORKSPACES
        }       
    },

    // Taskbar
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal"
        }
    },

    // niri Window
    "niri/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true
    },

    // Empty
    "custom/cat": {
        "format": "î»­ ",
		"on-click": "sh ~/.config/hypr/src/set-wallpaper.sh ~/Images/cat.jpg"
    },
    
    // Cliphist
    "custom/cliphist": {
        "format": "ïƒھ",
        "on-click": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh",
        "on-click-right": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh d",
        "on-click-middle": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh w",
        "tooltip": false
    },

    // Filemanager Launcher
    "custom/filemanager": {
        "format": "ïپ¼",
        "on-click": "dolphin",
        "tooltip": false
    },

    // Calculator
    "custom/calculator": {
        "format": "ï‡¬",
        "on-click": "qalculate-gtk",
        "tooltip": false
    },

    // Wofi Application Launcher
    "custom/appmenu": {
        // START APPS LABEL
        "format": "َ°£‡",
        // END APPS LABEL
        "on-click": "rofi -show drun",
        "tooltip": false
    },

    // Wofi Application Launcher
    "custom/appmenuicon": {
        "format": "َ°®¤",
        "on-click": "rofi -show drun",
        "tooltip": false
    },    

    // Power Menu
    "custom/exit": {
        "format": "ï€‘",
        "on-click": "wlogout",
        "tooltip": false
    },

    // Keyboard State
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ï€£",
            "unlocked": "ï‚œ"
        }
    },

    // System tray
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        // TIMEDATEFORMAT
        "format": "ï€—  {:%H:%M %a}",
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // START CLOCK FORMAT
        "format-alt": "َ°¸— {:%Y-%m-%d}"
        // END CLOCK FORMAT
    },

    // System
    "custom/system": {
        "format": "î‘³",
        "tooltip": false
    },

    // CPU
    "cpu": {
        "format": "ï’¼ {usage}%",
        "on-click": "kitty -T VPN htop"
    },

    // Memory
    "memory": {
        "format": "Mem {}% ",
        "on-click": "alacritty -e htop"
    },

    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {percentage_used}%",
        "path": "/",
        "on-click": "alacritty -e htop"
    }, 

    "niri/language": {
        // "format": "ï„œ  {short}",
		"format-en": "َ°‡پ",
		"format-ru": "َ°†±",
		"format-by": "َ°†¬",
		"on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next",
		"on-click-right": "hyprctl switchxkblayout at-translated-set-2-keyboard prev"
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "cpu",
			"disk",
			"battery",
            "backlight"
        ]
    },
    
    // Group Settings
    "group/settings": {
        "orientation": "horizontal",
        "modules": [
            "custom/settings",
        ]
    },

    // Group Quicklinks
    "group/quicklinks": {
        "orientation": "horizontal",
        "modules": [
            "custom/filemanager",
         ]
    },

    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon} ",
		"format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "format-ethernet": "َ°ˆ€ ",
        "format-disconnected": "",
        "tooltip-format": "{ifname} via {gwaddri}",
        "tooltip-format-wifi": "ï‡«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "{ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "sh ~/bin/wifimenu"
    },

    // Battery
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
		"interval": 3,
        "format": "{icon}",
        "format-charging": "{icon}",
        "format-plugged": "ï‡¦ ",
        "format-alt": "{icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
		"tooltip-format": "{capacity}%"
    },

    // Pulseaudio
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "َ°–پ",
        "format-muted": "َ°–پ",
        "format-icons": {
            "headphone": "ï€¥ ",
            "hands-free": "ï€¥",
            "headset": "َ°‹ژ",
            "phone": "ï‚• ",
            "portable": "ï‚• ",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format": "َ°‚¯",
        "format-disabled": "َ°‚²",
		"format-connected": "َ°‚±",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },

    // Other
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false,
    },

    // Idle Inhibator
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "ï‚œ",
            "deactivated": "ï€£"
        },
        "on-click-right": "hyprlock"        
    },

	"temperature": {
		"format": "{icon} {temperatureC}آ°C",
		"format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"]
	},

	"custom/notifications": {
		"exec": "swaync-client -swb",
		"return-type": "json",
		"format": "{icon}",
		"format-icons": {
			"notification": "َ°‚ڑ",
            "none": "َ°‚œ",
            "dnd-notification": "َ°‚›",
            "dnd-none": "َ°ھ‘",
            "inhibited-notification": "َ°‚›",
            "inhibited-none": "َ°ھ‘",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°ھ‘"
		},
		"on-click": "swaync-client -op"
	},

	"backlight": {
		"device": "intel_backlight",
		"format": "{icon}",
		"tooltip-format": "{percent}%",
		"format-icons": ["َ°ƒڑ", "َ°ƒ›", "َ°ƒœ", "َ°ƒ‍", "َ°ƒں", "َ°ƒ‌", "َ°ƒ "]
	},

	"custom/vpn": {
		"exec": "cat ~/.config/hypr/src/vpn-status",
		"interval": 1,
		"format": "{}",
		"on-click": "kitty -T VPN sh ~/.config/hypr/src/vpn.sh"
	}
}
